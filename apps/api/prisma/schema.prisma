generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  BUYER
  SELLER
  PLATFORM_OPERATOR
  PLATFORM_ADMIN
}

enum ShopRole {
  OWNER
  MANAGER
  STAFF
}

/// Business context owned by an Account (not the login identity itself).
enum TenantType {
  PARTICULAR
  STORE
}

enum TenantMemberRole {
  OWNER
  ADMIN
  MANAGER
  STAFF
  VIEWER
}

/// Backoffice iShopine staff only — never a seller "god admin".
enum PlatformStaffRole {
  OPS
  MODERATOR
  ENGINEER
  FINANCE
}

enum ShopStatus {
  PENDING
  ACTIVE
  SUSPENDED
  CLOSED
}

enum ShopType {
  ELECTRONICS
  FASHION
  SERVICES
  REAL_ESTATE_FURNITURE
  AUTOMOTIVE
  FOOD_GROCERY
  HEALTH_BEAUTY
  OTHER
}

enum AffiliateRewardStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

enum AdSlot {
  HOME_HERO
  HOME_STRIP
  MERCADO_TOP
  LOJAS_TOP
}

enum AdStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  OUT_OF_STOCK
}

/// Hybrid catalog: platform-wide vs store-owned category trees.
enum CategoryScope {
  GLOBAL
  STORE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  CASH
  MPESA
  EMOLA
  STRIPE
}

enum PaymentProvider {
  PAYSUITE
  STRIPE
  MPESA
  MANUAL
}

enum BillingPaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
  RESERVE
  RELEASE
}

enum AccountingEntryType {
  REVENUE
  EXPENSE
  ASSET
  LIABILITY
  EQUITY
  TRANSFER
}

enum AccountingEntryStatus {
  DRAFT
  POSTED
  VOID
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum VerificationPurpose {
  EMAIL_VERIFY
  LOGIN_OTP
  SENSITIVE_ACTION
  PASSWORD_RESET
}

enum NotificationType {
  ORDER
  MESSAGE
  REVIEW
  DISPUTE
  SYSTEM
  PROMO
}

enum DisputeStatus {
  OPEN
  IN_REVIEW
  RESOLVED_BUYER
  RESOLVED_SELLER
  CLOSED
}

enum CouponType {
  PERCENT
  FIXED
}

enum InboxStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  DEAD
}

enum OutboxStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
  DEAD
}

enum VulnSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FindingStatus {
  OPEN
  ACKNOWLEDGED
  MITIGATED
  ACCEPTED
  CLOSED
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  legalName   String?
  supportEmail String?
  supportPhone String?
  logoUrl     String?
  primaryColor String  @default("#61005D")
  isActive    Boolean  @default(true)

  plan        String   @default("platform")
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shops    Shop[]
  users    User[]
  settings PlatformSettings?

  @@index([slug])
}

model PlatformSettings {
  id                String @id @default(cuid())
  organizationId    String @unique
  marketplaceName   String @default("iShopine")
  tagline           String @default("Mercado aberto — compre e venda com confiança")
  currency          String @default("MZN")
  shippingFlatCents Int    @default(4900)
  freeShippingCents Int    @default(99900)
  requireSeller2fa  Boolean @default(true)
  requireEmailVerify Boolean @default(true)
  commissionBps     Int    @default(500)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model User {
  id               String       @id @default(cuid())
  organizationId   String
  email            String
  passwordHash     String?
  name             String
  phone            String?
  avatarUrl        String?
  platformRole     PlatformRole @default(BUYER)
  authProvider     AuthProvider @default(LOCAL)
  googleId         String?      @unique
  emailVerifiedAt  DateTime?
  totpSecret       String?
  totpEnabled      Boolean      @default(false)
  totpVerifiedAt   DateTime?
  backupCodesHash  String[]     @default([])
  canBuy           Boolean      @default(true)
  canSell          Boolean      @default(false)
  affiliateEligible Boolean     @default(false)
  isActive         Boolean      @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  organization      Organization        @relation(fields: [organizationId], references: [id])
  account           Account?
  addresses         Address[]
  cart              Cart?
  shopMemberships   ShopMember[]
  ownedShops        Shop[]              @relation("ShopOwner")
  buyerOrders       Order[]             @relation("BuyerOrders")
  inventoryMoves    InventoryMovement[] @relation("InventoryOperator")
  accountingEntries AccountingEntry[]   @relation("AccountingCreator")
  reviewedEntries   AccountingEntry[]   @relation("AccountingReviewer")
  verificationCodes EmailVerificationCode[]
  authSessions      AuthSession[]
  auditLogs         AuditLog[]
  wishlistItems     WishlistItem[]
  reviews           Review[]
  notifications     Notification[]
  conversationsAsBuyer Conversation[]   @relation("ConversationBuyer")
  messagesSent      Message[]
  disputesOpened    Dispute[]           @relation("DisputeOpener")
  shopFollows       ShopFollow[]
  couponsCreated    Coupon[]            @relation("CouponCreator")
  billingPayments   BillingPayment[]
  affiliateLinks    AffiliateLink[]
  affiliateRewards  AffiliateReward[]   @relation("AffiliateEarner")
  mediaUploads      MediaAsset[]        @relation("MediaUploader")

  @@unique([organizationId, email])
  @@index([email])
  @@index([platformRole])
  @@index([googleId])
  @@index([organizationId])
}

/// Login identity / person. Owns zero or more business tenants.
model Account {
  id        String   @id @default(cuid())
  userId    String   @unique
  email     String   @unique
  name      String
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownedTenants   Tenant[]            @relation("TenantOwner")
  memberships    TenantMembership[]
  platformStaff  PlatformStaff?
  wallets        Wallet[]
  subscriptions  Subscription[]
  invoices       PlatformInvoice[]
  mediaAssets    MediaAsset[]
  apiKeys        MerchantApiKey[]
  webhookEndpoints MerchantWebhookEndpoint[]

  @@index([email])
  @@index([isActive])
}

/// Isolated business context: PARTICULAR (at most one per account) or STORE (many).
model Tenant {
  id               String     @id @default(cuid())
  type             TenantType
  name             String
  slug             String     @unique
  ownerAccountId   String
  /// Set only when type = PARTICULAR; enforces one PARTICULAR per account.
  particularAccountId String? @unique
  /// Set only when type = STORE; links to legacy Shop during strangler.
  shopId           String?    @unique
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  owner        Account            @relation("TenantOwner", fields: [ownerAccountId], references: [id], onDelete: Cascade)
  shop         Shop?              @relation(fields: [shopId], references: [id], onDelete: SetNull)
  memberships  TenantMembership[]
  wallets      Wallet[]
  subscriptions Subscription[]
  usageRecords UsageRecord[]
  invoices     PlatformInvoice[]
  mediaAssets  MediaAsset[]
  flagOverrides FeatureFlagOverride[]
  apiKeys      MerchantApiKey[]
  webhookEndpoints MerchantWebhookEndpoint[]

  @@index([ownerAccountId])
  @@index([type, isActive])
}

model TenantMembership {
  id        String           @id @default(cuid())
  tenantId  String
  accountId String
  role      TenantMemberRole @default(STAFF)
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([tenantId, accountId])
  @@index([accountId])
  @@index([tenantId, isActive])
}

/// iShopine backoffice operators — platform observability/ops only.
model PlatformStaff {
  id        String            @id @default(cuid())
  accountId String            @unique
  role      PlatformStaffRole @default(OPS)
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([role, isActive])
}

model EmailVerificationCode {
  id        String              @id @default(cuid())
  userId    String?
  email     String
  codeHash  String
  purpose   VerificationPurpose
  attempts  Int                 @default(0)
  expiresAt DateTime
  consumedAt DateTime?
  metadata  Json?
  createdAt DateTime            @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, purpose])
  @@index([expiresAt])
}

model AuthSession {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String?
  userAgent        String?
  ipAddress        String?

  pendingTwoFactor Boolean  @default(false)
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  ipAddress  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Shop {
  id             String     @id @default(cuid())
  organizationId String
  ownerId        String
  name           String
  slug           String
  description    String?
  logoUrl        String?
  bannerUrl      String?
  /// Free-text policies (returns, shipping notes) — store depth Phase 5.
  policiesText   String?
  /// Weekly hours JSON, e.g. { mon: "09-18", … }.
  hoursJson      Json?
  status         ShopStatus @default(PENDING)
  shopType       ShopType   @default(OTHER)
  province       String     @default("Maputo Cidade")
  district       String     @default("KaMpfumo")
  latitude       Float      @default(-25.9692)
  longitude      Float      @default(32.5732)
  country        String     @default("MZ")
  ratingAvg      Float      @default(0)
  ratingCount    Int        @default(0)
  reputationScore Float     @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id])
  owner         User           @relation("ShopOwner", fields: [ownerId], references: [id])
  members       ShopMember[]
  products      Product[]
  categories    Category[]
  orders        Order[]        @relation("SellerOrders")
  conversations Conversation[]
  followers     ShopFollow[]
  reviews       Review[]
  affiliateLinks AffiliateLink[]
  ads            Ad[]
  tenant         Tenant?
  mediaAssets    MediaAsset[]

  @@unique([organizationId, slug])
  @@index([status])
  @@index([ownerId])
  @@index([organizationId])
  @@index([shopType])
  @@index([province, district])
}

model Ad {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String
  linkUrl   String
  slot      AdSlot   @default(HOME_STRIP)
  status    AdStatus @default(DRAFT)
  priority  Int      @default(0)
  startsAt  DateTime?
  endsAt    DateTime?
  shopId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop? @relation(fields: [shopId], references: [id], onDelete: SetNull)

  @@index([slot, status])
  @@index([priority])
  @@index([shopId])
  @@index([startsAt, endsAt])
}

model AffiliateLink {
  id            String   @id @default(cuid())
  userId        String
  code          String   @unique
  productId     String?
  shopId        String?
  label         String?
  clicks        Int      @default(0)
  conversions   Int      @default(0)
  rewardBps     Int      @default(200)
  pendingCents  Int      @default(0)
  earnedCents   Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  product  Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)
  shop     Shop?             @relation(fields: [shopId], references: [id], onDelete: SetNull)
  rewards  AffiliateReward[]

  @@index([userId])
  @@index([productId])
  @@index([shopId])
}

model AffiliateReward {
  id          String                 @id @default(cuid())
  linkId      String
  earnerId    String
  orderId     String?
  amountCents Int
  status      AffiliateRewardStatus  @default(PENDING)
  note        String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  link   AffiliateLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  earner User          @relation("AffiliateEarner", fields: [earnerId], references: [id], onDelete: Cascade)

  @@index([earnerId, status])
  @@index([linkId])
}

model ShopMember {
  id        String   @id @default(cuid())
  shopId    String
  userId    String
  role      ShopRole @default(STAFF)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([shopId, userId])
  @@index([userId])
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  label      String   @default("Principal")
  street     String
  number     String
  complement String?
  district   String
  city       String
  state      String
  zipCode    String
  country    String   @default("MZ")
  latitude   Float?
  longitude  Float?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@index([userId])
}

model Category {
  id          String         @id @default(cuid())
  name        String
  slug        String
  description String?
  imageUrl    String?
  parentId    String?
  sortOrder   Int            @default(0)
  isActive    Boolean        @default(true)
  /// GLOBAL = marketplace taxonomy; STORE = seller-owned tree (requires shopId).
  scope       CategoryScope  @default(GLOBAL)
  shopId      String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
  shop     Shop?      @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, slug])
  @@index([parentId])
  @@index([slug])
  @@index([scope, shopId])
  @@index([shopId])
}

model Product {
  id               String        @id @default(cuid())
  shopId           String
  sku              String
  name             String
  slug             String
  description      String
  shortDescription String?
  priceCents       Int
  compareAtCents   Int?
  costCents        Int           @default(0)
  stock            Int           @default(0)
  reservedStock    Int           @default(0)
  status           ProductStatus @default(DRAFT)
  categoryId       String?
  brand            String?
  material         String?
  dimensions       String?
  weightKg         Float?
  color            String?
  condition        String        @default("new")
  featured         Boolean       @default(false)
  metaTitle        String?
  metaDescription  String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  shop          Shop                @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category      Category?           @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  cartItems     CartItem[]
  orderItems    OrderItem[]
  movements     InventoryMovement[]
  wishlistItems WishlistItem[]
  reviews       Review[]
  conversations Conversation[]
  affiliateLinks AffiliateLink[]

  @@unique([shopId, sku])
  @@unique([shopId, slug])
  @@index([categoryId])
  @@index([status])
  @@index([featured])
  @@index([shopId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  publicId  String?
  alt       String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Cart {
  id        String   @id @default(cuid())
  userId    String   @unique
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CartItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  buyerId         String
  sellerShopId    String
  addressId       String?
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(PIX)
  subtotalCents   Int
  shippingCents   Int           @default(0)
  discountCents   Int           @default(0)
  platformFeeCents Int          @default(0)
  totalCents      Int
  notes           String?
  /// Affiliate referral code captured at checkout (`?ref=`).
  affiliateCode   String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  buyer             User              @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerShop        Shop              @relation("SellerOrders", fields: [sellerShopId], references: [id])
  address           Address?          @relation(fields: [addressId], references: [id])
  items             OrderItem[]
  payments          Payment[]
  accountingEntries AccountingEntry[]
  events            OrderEvent[]
  couponRedemptions CouponRedemption[]
  disputes          Dispute[]
  couponCode        String?
  shipments         Shipment[]

  @@index([buyerId])
  @@index([sellerShopId])
  @@index([status])
  @@index([orderNumber])
  @@index([createdAt])
  @@index([affiliateCode])
}

model OrderItem {
  id             String @id @default(cuid())
  orderId        String
  productId      String
  productName    String
  productSku     String
  unitPriceCents Int
  quantity       Int
  totalCents     Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id          String        @id @default(cuid())
  orderId     String
  method      PaymentMethod
  status      PaymentStatus @default(PENDING)
  amountCents Int
  externalId  String?
  paidAt      DateTime?
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
}

model BillingPayment {
  id                    String               @id @default(cuid())
  buyerId               String
  provider              PaymentProvider      @default(PAYSUITE)
  status                BillingPaymentStatus @default(PENDING)
  amountCents           Int
  currency              String               @default("MZN")
  orderIds              String[]

  method                String?

  reference             String               @unique
  paysuitePaymentId     String?              @unique
  paysuiteCheckoutUrl   String?
  paysuiteTransactionId String?
  msisdn                String?

  stripeSessionId       String?              @unique
  stripePaymentIntentId String?
  mpesaConversationId   String?
  mpesaTransactionId    String?
  mpesaThirdPartyRef    String?
  failureReason         String?
  metadata              Json?
  paidAt                DateTime?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  buyer User @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([buyerId])
  @@index([provider, status])
  @@index([createdAt])
  @@index([paysuitePaymentId])
}

model BillingWebhookEvent {
  id          String    @id @default(cuid())
  requestId   String    @unique
  event       String
  payload     Json
  paymentId   String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([event])
  @@index([createdAt])
}

model InventoryMovement {
  id         String                @id @default(cuid())
  productId  String
  type       InventoryMovementType
  quantity   Int
  reason     String
  reference  String?
  operatorId String?
  createdAt  DateTime              @default(now())

  product  Product @relation(fields: [productId], references: [id])
  operator User?   @relation("InventoryOperator", fields: [operatorId], references: [id])

  @@index([productId])
  @@index([createdAt])
}

model AccountingAccount {
  id          String              @id @default(cuid())
  code        String              @unique
  name        String
  type        AccountingEntryType
  description String?
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  debitEntries  AccountingEntry[] @relation("DebitAccount")
  creditEntries AccountingEntry[] @relation("CreditAccount")

  @@index([type])
}

model AccountingEntry {
  id              String                @id @default(cuid())
  entryNumber     String                @unique
  description     String
  type            AccountingEntryType
  status          AccountingEntryStatus @default(DRAFT)
  amountCents     Int
  entryDate       DateTime              @default(now())
  debitAccountId  String
  creditAccountId String
  orderId         String?
  createdById     String
  reviewedById    String?
  notes           String?
  postedAt        DateTime?
  voidedAt        DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  debitAccount  AccountingAccount @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount AccountingAccount @relation("CreditAccount", fields: [creditAccountId], references: [id])
  order         Order?            @relation(fields: [orderId], references: [id])
  createdBy     User              @relation("AccountingCreator", fields: [createdById], references: [id])
  reviewedBy    User?             @relation("AccountingReviewer", fields: [reviewedById], references: [id])

  @@index([status])
  @@index([entryDate])
  @@index([type])
  @@index([orderId])
}

model MediaAsset {
  id           String   @id @default(cuid())
  url          String
  publicId     String?
  provider     String   @default("local")
  mimeType     String?
  sizeBytes    Int?
  folder       String?
  alt          String?
  accountId    String?
  tenantId     String?
  shopId       String?
  uploadedById String?
  createdAt    DateTime @default(now())

  account    Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  shop       Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)
  uploadedBy User?    @relation("MediaUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([provider])
  @@index([folder])
  @@index([accountId])
  @@index([tenantId])
  @@index([shopId])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  shopId    String
  orderId   String?
  rating    Int
  title     String?
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
  @@index([shopId])
  @@index([rating])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(SYSTEM)
  title     String
  body      String
  href      String?
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([createdAt])
}

model Conversation {
  id        String   @id @default(cuid())
  buyerId   String
  shopId    String
  productId String?
  subject   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer    User      @relation("ConversationBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  messages Message[]

  @@index([buyerId, shopId])
  @@index([buyerId])
  @@index([shopId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  readAt         DateTime?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Coupon {
  id              String     @id @default(cuid())
  code            String     @unique
  type            CouponType
  value           Int
  minSubtotalCents Int       @default(0)
  maxUses         Int?
  usedCount       Int        @default(0)
  startsAt        DateTime   @default(now())
  endsAt          DateTime?
  isActive        Boolean    @default(true)
  createdById     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  createdBy   User?              @relation("CouponCreator", fields: [createdById], references: [id])
  redemptions CouponRedemption[]

  @@index([code])
  @@index([isActive])
}

model CouponRedemption {
  id          String   @id @default(cuid())
  couponId    String
  orderId     String
  amountCents Int
  createdAt   DateTime @default(now())

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([couponId, orderId])
}

model Dispute {
  id          String        @id @default(cuid())
  orderId     String
  openedById  String
  reason      String
  description String
  status      DisputeStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  resolvedAt  DateTime?

  order    Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  openedBy User  @relation("DisputeOpener", fields: [openedById], references: [id])

  @@index([orderId])
  @@index([status])
  @@index([openedById])
}

model ShopFollow {
  id        String   @id @default(cuid())
  userId    String
  shopId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([userId, shopId])
  @@index([shopId])
}

model OrderEvent {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}

model InboxMessage {
  id            String      @id @default(cuid())
  source        String
  messageKey    String
  eventType     String
  payload       Json
  headers       Json?
  status        InboxStatus @default(RECEIVED)
  attempts      Int         @default(0)
  maxAttempts   Int         @default(5)
  lastError     String?
  receivedAt    DateTime    @default(now())
  processedAt   DateTime?
  nextAttemptAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([source, messageKey])
  @@index([status, nextAttemptAt])
  @@index([eventType])
  @@index([receivedAt])
}

model OutboxMessage {
  id            String       @id @default(cuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  headers       Json?
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  maxAttempts   Int          @default(8)
  lastError     String?
  availableAt   DateTime     @default(now())
  publishedAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status, availableAt])
  @@index([aggregateType, aggregateId])
  @@index([eventType])
  @@index([createdAt])
}

model IdempotencyRecord {
  id           String   @id @default(cuid())
  scope        String
  key          String
  requestHash  String?
  responseCode Int?
  responseBody Json?
  status       String   @default("STARTED")
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([scope, key])
  @@index([expiresAt])
}

model ReadProjection {
  id           String   @id @default(cuid())
  name         String
  partitionKey String
  version      Int      @default(1)
  data         Json
  checksum     String?
  projectedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([name, partitionKey])
  @@index([name, updatedAt])
}

model SecurityFinding {
  id          String        @id @default(cuid())
  code        String
  severity    VulnSeverity
  title       String
  description String
  surface     String
  status      FindingStatus @default(OPEN)
  evidence    Json?
  remediation String?
  detectedAt  DateTime      @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([code, surface])
  @@index([severity, status])
  @@index([detectedAt])
}

/* ── Phase 4: Wallet + Pricing + Subscriptions (platform billing) ── */

enum WalletOwnerType {
  ACCOUNT
  TENANT
  PLATFORM
}

enum LedgerEntryType {
  CREDIT
  DEBIT
  HOLD
  RELEASE
  ADJUSTMENT
}

enum PricingPlanCode {
  FREE
  STARTER
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

enum UsageMetric {
  ORDERS
  PRODUCTS
  CHECKOUTS
  API_CALLS
}

enum PlatformInvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
}

model Wallet {
  id             String          @id @default(cuid())
  /// Unique key: `platform` | `account:<id>` | `tenant:<id>`
  key            String          @unique
  ownerType      WalletOwnerType
  accountId      String?
  tenantId       String?
  currency       String          @default("MZN")
  availableCents Int             @default(0)
  heldCents      Int             @default(0)
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  account Account?            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tenant  Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ledger  WalletLedgerEntry[]

  @@index([accountId])
  @@index([tenantId])
  @@index([ownerType])
}

model WalletLedgerEntry {
  id               String          @id @default(cuid())
  walletId         String
  type             LedgerEntryType
  amountCents      Int
  balanceAfterCents Int
  reference        String?
  note             String?
  metadata         Json?
  createdAt        DateTime        @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([reference])
}

model PricingPlan {
  id                String          @id @default(cuid())
  code              PricingPlanCode @unique
  name              String
  description       String?
  monthlyPriceCents Int             @default(0)
  /// Included orders per billing period (null = unlimited).
  includedOrders    Int?
  /// Overage price per order above includedOrders.
  overageOrderCents Int             @default(0)
  commissionBps     Int?
  features          Json?
  sortOrder         Int             @default(0)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  subscriptions Subscription[]

  @@index([isActive, sortOrder])
}

model Subscription {
  id                 String             @id @default(cuid())
  planId             String
  accountId          String?
  tenantId           String?
  status             SubscriptionStatus @default(TRIALING)
  currentPeriodStart DateTime           @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  plan    PricingPlan @relation(fields: [planId], references: [id])
  account Account?    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tenant  Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([accountId, status])
  @@index([tenantId, status])
  @@index([planId])
}

model UsageRecord {
  id        String      @id @default(cuid())
  tenantId  String
  metric    UsageMetric
  quantity  Int         @default(1)
  /// YYYY-MM period key for aggregation.
  periodKey String
  reference String?
  createdAt DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, metric, periodKey])
  @@index([periodKey])
}

model PlatformInvoice {
  id          String                @id @default(cuid())
  accountId   String?
  tenantId    String?
  periodKey   String
  status      PlatformInvoiceStatus @default(DRAFT)
  subtotalCents Int                 @default(0)
  taxCents    Int                   @default(0)
  totalCents  Int                   @default(0)
  currency    String                @default("MZN")
  lineItems   Json?
  dueAt       DateTime?
  paidAt      DateTime?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  tenant  Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, periodKey])
  @@index([accountId, periodKey])
  @@index([status])
}

/* ── Phase 5: Feature Flags + Developer Platform ── */

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  overrides FeatureFlagOverride[]

  @@index([enabled])
}

/// scopeKey: `global` | `tenant:<id>` | `plan:<PricingPlanCode>`
model FeatureFlagOverride {
  id        String   @id @default(cuid())
  flagId    String
  scopeKey  String
  tenantId  String?
  enabled   Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  flag   FeatureFlag @relation(fields: [flagId], references: [id], onDelete: Cascade)
  tenant Tenant?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([flagId, scopeKey])
  @@index([tenantId])
  @@index([scopeKey])
}

model MerchantApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  accountId  String
  name       String
  keyPrefix  String
  keyHash    String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([accountId])
  @@index([keyPrefix])
  @@index([keyHash])
}

model MerchantWebhookEndpoint {
  id        String   @id @default(cuid())
  tenantId  String
  accountId String
  url       String
  secret    String
  /// Event types this endpoint subscribes to (empty = all platform events for tenant).
  events    String[] @default([])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account    Account                   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  deliveries MerchantWebhookDelivery[]

  @@index([tenantId, isActive])
  @@index([accountId])
}

model MerchantWebhookDelivery {
  id          String   @id @default(cuid())
  endpointId  String
  eventType   String
  payload     Json
  status      String   @default("PENDING")
  attempts    Int      @default(0)
  responseCode Int?
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  endpoint MerchantWebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, createdAt])
  @@index([status])
  @@index([eventType])
}

/* ── Phase 7: Logistics carriers + shipments ── */

enum CarrierCode {
  FLAT_RATE
  FREE_THRESHOLD
  STORE_PICKUP
  MANUAL
}

enum ShipmentStatus {
  PENDING
  LABEL_CREATED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
}

model Shipment {
  id            String         @id @default(cuid())
  orderId       String
  carrierCode   CarrierCode
  /// Service method mirrored from quote (FLAT/FREE/PICKUP/CUSTOM).
  method        String
  status        ShipmentStatus @default(PENDING)
  trackingCode  String?
  labelUrl      String?
  amountCents   Int            @default(0)
  destinationProvince String?
  destinationDistrict String?
  weightKg      Float?
  metadata      Json?
  shippedAt     DateTime?
  deliveredAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  order  Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events ShipmentEvent[]

  @@index([orderId])
  @@index([carrierCode, status])
  @@index([trackingCode])
  @@index([status])
}

model ShipmentEvent {
  id          String   @id @default(cuid())
  shipmentId  String
  status      ShipmentStatus
  note        String?
  rawPayload  Json?
  createdAt   DateTime @default(now())

  shipment Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, createdAt])
}

/// Tarifas por zona geográfica (província/cidade de Moçambique).
/// Usadas pelos adapters FLAT_RATE / FREE_THRESHOLD / MANUAL para cotação real.
model ShippingRateZone {
  id             String      @id @default(cuid())
  carrierCode    CarrierCode
  /// Província (ex: "Maputo", "Gaza"). Null = fallback nacional.
  province       String?
  /// Cidade/distrito opcional para override fino.
  city           String?
  /// Preço em centavos MZN para a zona.
  priceCents     Int
  etaMinDays     Int         @default(2)
  etaMaxDays     Int         @default(7)
  /// Peso máximo em gramas aceite nesta zona (null = sem limite).
  maxWeightGrams Int?
  active         Boolean     @default(true)
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([carrierCode, province, city])
  @@index([carrierCode, active, sortOrder])
  @@index([province, city])
}
