DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"
WEB_URL="http://localhost:3000"
APP_URL="http://localhost:4000"
PLATFORM_ORG_SLUG="ishopine"
UPLOAD_PROVIDER="local"
UPLOAD_DIR="uploads"
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/auth/google/callback"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="iShopine <noreply@ishopine.com>"
NODE_ENV="development"

# PaySuite (paysuite.co.mz) — primary payments for Mozambique
# Docs: https://paysuite.tech/docs/  · SDK: https://github.com/hypertech-lda/paysuite-php-sdk
PAYSUITE_TOKEN=""
PAYSUITE_WEBHOOK_SECRET=""
PAYSUITE_BASE_URL="https://paysuite.tech/api/v1"
PAYSUITE_TIMEOUT_MS="30000"
PAYSUITE_MAX_RETRIES="3"
# Local demos only (PaySuite has no sandbox — real charges when token is set):
PAYSUITE_SIMULATE="true"
