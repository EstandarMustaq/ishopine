{
  "name": "ishopine-marketplace",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter @ishopine/web dev",
    "dev:api": "pnpm --filter @ishopine/api start:dev",
    "build": "pnpm --filter @ishopine/api build && pnpm --filter @ishopine/web build",
    "db:generate": "pnpm --filter @ishopine/api prisma:generate",
    "db:migrate": "pnpm --filter @ishopine/api prisma:migrate",
    "db:seed": "pnpm --filter @ishopine/api prisma:seed",
    "db:push": "pnpm --filter @ishopine/api prisma:push",
    "lint": "pnpm -r run lint"
  }
}
